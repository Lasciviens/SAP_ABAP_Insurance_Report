  METHOD tb_save_comment.
    READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX gv_row_id.
    CHECK sy-subrc EQ 0.
    CHECK <lfs_alv>-zcomment NE gv_screen_comment.

    <lfs_alv>-zcomment = gv_screen_comment.
    UPDATE zinsusale
         SET zcomment = @<lfs_alv>-zcomment
       WHERE polisenr = @<lfs_alv>-polisenr.

    IF sy-subrc EQ 0.
      COMMIT WORK.
      mo_alv_grid->refresh_table_display( is_stable = gs_stable ).
      MESSAGE 'Comment successfully updated!' TYPE 'S'.
    ELSE.
      MESSAGE 'Failed to update database!' TYPE 'S' DISPLAY LIKE 'E'.
    ENDIF.

