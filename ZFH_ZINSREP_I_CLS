  METHOD tb_execute_mail.
    READ TABLE gt_mail_queue ASSIGNING FIELD-SYMBOL(<ls_mail>) WITH TABLE KEY mail_id = iv_mail_id.
    CHECK sy-subrc = 0.

    TRY.
        DATA(lo_send_request) = cl_bcs=>create_persistent( ).

        DATA: lt_html_body TYPE TABLE OF soli,
              ls_html_line TYPE soli.

        ls_html_line-line = '<html style="font-family: Arial, sans-serif; font-size: 14px;"><body>'.
        APPEND ls_html_line TO lt_html_body.

        LOOP AT <ls_mail>-mail_body INTO DATA(lv_text_line).
          ls_html_line-line = lv_text_line && '<br>'.
          APPEND ls_html_line TO lt_html_body.
        ENDLOOP.

        ls_html_line-line = '<br><br>Kind regards,<br>IT Support</body></html>'.
        APPEND ls_html_line TO lt_html_body.

        DATA(lo_document) = cl_document_bcs=>create_document(
                              i_type    = 'HTM'
                              i_text    = lt_html_body
                              i_subject = CONV #( <ls_mail>-mail_subj ) ).
        lo_send_request->set_document( lo_document ).

        " From Addresses
        DATA: lo_sender TYPE REF TO if_sender_bcs.
        IF rb_from_it = abap_true.
          lo_sender = cl_cam_address_bcs=>create_internet_address( 'itsupport@power.no' ).
        ELSE.
*          lo_sender = cl_sapuser_bcs=>create( sy-uname ).
          DATA(lv_sender_email) = me->find_mail( sy-uname ).
          IF lv_sender_email IS INITIAL.
            lv_sender_email = 'itsupport@power.no'. " Fallback (No mail address -> IT Support)
          ENDIF.
          lo_sender = cl_cam_address_bcs=>create_internet_address( CONV #( lv_sender_email ) ).
        ENDIF.
        lo_send_request->set_sender( lo_sender ).

        DATA: lt_emails TYPE TABLE OF string,
              lv_email  TYPE string.

        " To Addresses
        REPLACE ALL OCCURRENCES OF ',' IN <ls_mail>-mail_to WITH ';'.
        SPLIT <ls_mail>-mail_to AT ';' INTO TABLE lt_emails.
        LOOP AT lt_emails INTO lv_email.
          CONDENSE lv_email.
          CHECK lv_email IS NOT INITIAL.
          IF lv_email NA '@'.
            DATA(lv_found_mail) = me->find_mail( CONV #( lv_email ) ).
            IF lv_found_mail IS NOT INITIAL.
              lv_email = lv_found_mail. " Uname to Mail
            ELSE.
              CONTINUE.
            ENDIF.
          ENDIF.
          DATA(lo_recipient) = cl_cam_address_bcs=>create_internet_address( CONV #( lv_email ) ).
          lo_send_request->add_recipient( i_recipient = lo_recipient ).
        ENDLOOP.

        " --- CC (Copy) Addresses ---
        CLEAR lt_emails.
        IF <ls_mail>-mail_cc IS NOT INITIAL.
          " Ensure consistent separator by replacing commas with semicolons
          REPLACE ALL OCCURRENCES OF ',' IN <ls_mail>-mail_cc WITH ';'.
          SPLIT <ls_mail>-mail_cc AT ';' INTO TABLE lt_emails.

          LOOP AT lt_emails INTO lv_email.
            CONDENSE lv_email.
            CHECK lv_email IS NOT INITIAL.

            " SMART CHECK (Also applies to CC): If no '@' is found, try to find the email via method!
            IF lv_email NA '@'.
              lv_found_mail = me->find_mail( CONV #( lv_email ) ).
              IF lv_found_mail IS NOT INITIAL.
                lv_email = lv_found_mail.
              ELSE.
                CONTINUE.
              ENDIF.
            ENDIF.

            DATA(lo_cc) = cl_cam_address_bcs=>create_internet_address( CONV #( lv_email ) ).
            " Add as CC recipient (i_copy = abap_true)
            lo_send_request->add_recipient( i_recipient = lo_cc i_copy = abap_true ).
          ENDLOOP.
        ENDIF.

        " SEND MAIL!
        DATA(lv_sent) = lo_send_request->send( i_with_error_screen = abap_true ).
        IF lv_sent = abap_true.
          COMMIT WORK.
          rv_success = abap_true.

          LOOP AT <ls_mail>-rows INTO DATA(ls_sel_row).
            me->add_auto_comment( iv_index = ls_sel_row-index iv_action = |Mail sent. Ticket ID: #{ iv_mail_id }| ).
          ENDLOOP.
        ENDIF.

      CATCH cx_bcs INTO DATA(lo_bcs_exc).
        MESSAGE |Error sending mail: { lo_bcs_exc->get_text( ) }| TYPE 'S' DISPLAY LIKE 'E'.
    ENDTRY.
  ENDMETHOD.

