  METHOD tb_find_imei.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    IF lines( lt_rows ) > 1.
      MESSAGE 'Select only 1 line to find IMEI' TYPE 'S' DISPLAY LIKE 'W'.
      RETURN.
    ENDIF.

    READ TABLE lt_rows INTO DATA(ls_row) INDEX 1.
    READ TABLE mt_alv INDEX ls_row-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
    CHECK sy-subrc EQ 0.

    " 1. We use INTO TABLE instead of SELECT SINGLE
    TYPES: BEGIN OF ty_imei,
             sernr TYPE sernr,
           END OF ty_imei.
    DATA: lt_imei TYPE TABLE OF ty_imei.

    SELECT objk~sernr
      FROM vbfa
      INNER JOIN vepo  ON vepo~vbeln  = vbfa~vbeln
      INNER JOIN ser06 ON ser06~venum = vepo~venum
      INNER JOIN objk  ON objk~obknr  = ser06~obknr
      INTO TABLE @lt_imei
      WHERE vbfa~vbelv   = @<lfs_alv>-refnr
        AND vbfa~vbtyp_n = 'J'.

    IF sy-subrc <> 0 OR lt_imei IS INITIAL.
      MESSAGE 'Could not find any IMEI in document flow for this record!' TYPE 'S' DISPLAY LIKE 'W'.
      RETURN.
    ENDIF.

    " Clean up duplicate IMEIs
    SORT lt_imei BY sernr.
    DELETE ADJACENT DUPLICATES FROM lt_imei COMPARING sernr.

    DATA: lv_selected_imei TYPE sernr.

    " 2. DECISION MECHANISM (The Highlight)
    IF lines( lt_imei ) = 1.
      lv_selected_imei = lt_imei[ 1 ]-sernr. " If there's only 1, take it directly
    ELSE.
      " If there are more than 1, trigger the standard SAP Selection Pop-up!
      DATA: lt_return TYPE TABLE OF ddshretval.
      CALL FUNCTION 'F4IF_INT_TABLE_VALUE_REQUEST'
        EXPORTING
          retfield     = 'SERNR'
          value_org    = 'S'
          window_title = 'Multiple IMEIs Found! Select one:'
        TABLES
          value_tab    = lt_imei
          return_tab   = lt_return
        EXCEPTIONS
          OTHERS       = 3.

      IF sy-subrc = 0 AND lt_return IS NOT INITIAL.
        lv_selected_imei = lt_return[ 1 ]-fieldval. " Take what the user selected
      ELSE.
        MESSAGE 'Action cancelled.' TYPE 'S'.
        RETURN.
      ENDIF.
    ENDIF.

    " 3. RECORDING AND CONFIRMATION PART
    DATA: lv_answer TYPE c.
    CALL FUNCTION 'POPUP_TO_CONFIRM'
      EXPORTING
        titlebar              = 'IMEI Found!'
        text_question         = |IMEI number { lv_selected_imei } found. Do you want to save it in ZINSUSALE?|
        text_button_1         = 'OK'
        text_button_2         = 'NO'
        display_cancel_button = abap_false
      IMPORTING
        answer                = lv_answer.

    IF lv_answer = '1'. " OK clicked
      UPDATE zinsusale
         SET zz_imei  = @lv_selected_imei
       WHERE polisenr = @<lfs_alv>-polisenr.

      IF sy-subrc = 0.
        COMMIT WORK.
        " If you want to see the IMEI info immediately on the ALV screen, you can uncomment the next 2 lines:
        <lfs_alv>-zz_imei = lv_selected_imei.
        mo_alv_grid->refresh_table_display( is_stable = gs_stable ).

        MESSAGE |IMEI { lv_selected_imei } successfully added to { <lfs_alv>-polisenr }| TYPE 'S'.
      ELSE.
        MESSAGE 'Error occurred while updating ZINSUSALE!' TYPE 'S' DISPLAY LIKE 'E'.
      ENDIF.
    ELSE.
      MESSAGE 'Action cancelled. Nothing changed in ZINSUSALE.' TYPE 'S'.
    ENDIF.

  ENDMETHOD.

