  METHOD tb_reset_flag.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    DATA: lv_success_count TYPE i.

    LOOP AT lt_rows ASSIGNING FIELD-SYMBOL(<lfs_rows>). "Loop at selected rows
      READ TABLE mt_alv INDEX <lfs_rows>-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
      CHECK sy-subrc EQ 0."Continue to next row

      UPDATE zupdt_bp_token
        SET bprequestsent = @space
        WHERE refnr EQ @<lfs_alv>-refnr.

      IF sy-subrc EQ 0.
        lv_success_count = lv_success_count + 1.
        me->add_message(
          EXPORTING
            iv_type = 'S'
            iv_text = |Policy: { <lfs_alv>-polisenr } , Ref nr: { <lfs_alv>-refnr } is resetted | ).
      ELSE.
        me->add_message(
          EXPORTING
            iv_type = 'E'
            iv_text = |Could not find { <lfs_alv>-refnr } in table ZUPDT_BP_TOKEN | ).
      ENDIF.

    ENDLOOP.

    IF lv_success_count > 0.
      COMMIT WORK AND WAIT.
    ENDIF.
    me->display_all_messages( ).
    mo_alv_grid->refresh_table_display( is_stable = gs_stable ).
  ENDMETHOD.

  METHOD tb_find_imei.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.
    DATA lv_imei TYPE sernr.
    IF lines( lt_rows ) > 1.
      MESSAGE |Select only 1 line to find IMEI| TYPE 'S' DISPLAY LIKE 'W'.
      RETURN.
    ENDIF.

    READ TABLE lt_rows INTO DATA(ls_row) INDEX 1.
    READ TABLE mt_alv INDEX ls_row-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
    CHECK sy-subrc EQ 0.

    " VBFA - VBELV = Refnr && VBTYP_N = 'J' => VEPO VBELN => SER06  VENUM => OBJK OBKNR => Get SERNR as IMEI
    " If necessary add 0's
    " DATA: lv_vbelv TYPE vbeln_von.
    " lv_vbelv = |{ <lfs_alv>-refnr ALPHA = IN }|.

    SELECT SINGLE objk~sernr
      FROM vbfa
      INNER JOIN vepo  ON vepo~vbeln  = vbfa~vbeln
      INNER JOIN ser06 ON ser06~venum = vepo~venum
      INNER JOIN objk  ON objk~obknr  = ser06~obknr
      INTO @lv_imei
      WHERE vbfa~vbelv   = @<lfs_alv>-refnr
        AND vbfa~vbtyp_n = 'J'.

    IF sy-subrc EQ 0.

      DATA: lv_answer TYPE c.

      CALL FUNCTION 'POPUP_TO_CONFIRM'
        EXPORTING
          titlebar              = 'IMEI Found!'
          text_question         = |IMEI number { lv_imei } found. Do you want to save it in ZINSUSALE?|
          text_button_1         = 'OK'
          text_button_2         = 'NO'
          display_cancel_button = abap_false
        IMPORTING
          answer                = lv_answer.

      IF lv_answer = '1'. " 1 Button (OK) clicked

        UPDATE zinsusale
           SET zz_imei     = @lv_imei
         WHERE polisenr = @<lfs_alv>-polisenr.

        IF sy-subrc = 0.
          COMMIT WORK.

          " Update ALV?
*           <lfs_alv>-imei = lv_imei.
*           mo_alv_grid->refresh_table_display( is_stable = gs_stable ).

          MESSAGE |IMEI { lv_imei } successfully added to { <lfs_alv>-polisenr }| TYPE 'S'.
        ELSE.
          MESSAGE 'Error occurred while updating ZINSUSALE!' TYPE 'S' DISPLAY LIKE 'E'.
        ENDIF.

      ELSE. " 1 Button (NO) clicked
        MESSAGE 'Action cancelled. Nothing changed in ZINSUSALE.' TYPE 'S'.
      ENDIF.

    ELSE.
      MESSAGE 'Could not find any IMEI in document flow for this record!' TYPE 'S' DISPLAY LIKE 'W'.
    ENDIF.

  ENDMETHOD.

