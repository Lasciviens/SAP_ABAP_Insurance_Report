    " Prepare the Queue (Drafts)
    DATA: ls_queue TYPE ty_mail_queue.

    LOOP AT lt_temp_grp INTO DATA(ls_grp).
      CLEAR ls_queue.
      ls_queue-country = ls_grp-country.
      ls_queue-store   = ls_grp-store.
      ls_queue-rows    = ls_grp-rows.
      ls_queue-mail_to = |vip@power.{ to_lower( ls_grp-country ) }|.

