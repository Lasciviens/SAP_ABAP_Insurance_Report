  METHOD tb_details.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    DATA: lt_selfields TYPE TABLE OF se16n_seltab,
          ls_selfield  TYPE se16n_seltab.

    LOOP AT lt_rows ASSIGNING FIELD-SYMBOL(<lfs_rows>). "Loop at selected rows
      READ TABLE mt_alv INDEX <lfs_rows>-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
      CHECK sy-subrc EQ 0."Continue to next row

      CLEAR ls_selfield.
      ls_selfield-sign = 'I'.
      ls_selfield-option = 'EQ'.

      IF iv_table = 'ZINSUSALE'.
        ls_selfield-field = 'POLISENR'.
        ls_selfield-low   = <lfs_alv>-polisenr.
      ELSEIF iv_table = 'ZUPDT_BP_TOKEN'.
        ls_selfield-field = 'REFNR'.
        ls_selfield-low   = <lfs_alv>-refnr.
      ENDIF.

      APPEND ls_selfield TO lt_selfields.
    ENDLOOP.

    CALL FUNCTION 'SE16N_INTERFACE'
      EXPORTING
        i_tab        = iv_table         " Table name in SE16N
        i_edit       = ' '              " Single-Character Indicator
        i_sapedit    = ' '              " Single-Character Indicator
*       i_no_txt     = ' '              " Do not select any texts
        i_max_lines  = 500              " Maximum Number of Hits
      TABLES
        it_selfields = lt_selfields     " Table Display: Selection Criteria
      EXCEPTIONS
        no_values    = 1                " No Values Found
        OTHERS       = 2.
    IF sy-subrc NE 0.
      MESSAGE | Could not bring details in { iv_table } | TYPE 'S' DISPLAY LIKE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD tb_edit_policy.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    DATA: lt_sellist TYPE TABLE OF vimsellist,
          ls_sellist TYPE vimsellist.

    LOOP AT lt_rows ASSIGNING FIELD-SYMBOL(<lfs_rows>).
      READ TABLE mt_alv INDEX <lfs_rows>-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
      CHECK sy-subrc EQ 0.

      " Prepare SM30 Filter (POLISENR = Selected Policy)
      CLEAR ls_sellist.
      ls_sellist-viewfield = 'POLISENR'.
      ls_sellist-operator  = 'EQ'.
      ls_sellist-value     = <lfs_alv>-polisenr.
      ls_sellist-and_or    = 'OR'. " If multiple rows are selected, connect with OR
      APPEND ls_sellist TO lt_sellist.
    ENDLOOP.

    " RULE: In the SM30 filter, the AND/OR connector of the last row must be left blank
    IF lt_sellist IS NOT INITIAL.
      DATA(lv_last) = lines( lt_sellist ).
      lt_sellist[ lv_last ]-and_or = space.
    ENDIF.

    " Call SM30 (Action 'U' = Update / Change Mode)
    CALL FUNCTION 'VIEW_MAINTENANCE_CALL'
      EXPORTING
        action      = 'U'
        view_name   = 'ZINSUSALE'
      TABLES
        dba_sellist = lt_sellist
      EXCEPTIONS
        OTHERS      = 15.

    IF sy-subrc <> 0.
      MESSAGE 'Error opening SM30 for ZINSUSALE! Check if it exists in ZINSUSALE' TYPE 'S' DISPLAY LIKE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD tb_update_token.
    DATA(lt_rows) = me->get_selected_rows( ).

    IF lines( lt_rows ) NE 1.
      MESSAGE 'Please select exactly ONE row for Token Update!' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    READ TABLE lt_rows INTO DATA(ls_row) INDEX 1.
    READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX ls_row-index.
    CHECK sy-subrc = 0.

    IF <lfs_alv>-zzsubscr IS INITIAL.
      MESSAGE | Policy: { <lfs_alv>-polisenr } is not a subscription! | TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.
    " Let's clear the screen variables completely
    CLEAR: zupdt_bp_token-partner_guid, gv_scr_guid, gv_scr_token, gv_scr_refnr, gv_scr_webshop, gv_scr_bp, gv_scr_msg, gv_refnr_exist.

    " Take the data from ALV ONLY ONCE (as per your instruction)
    gv_scr_refnr = <lfs_alv>-refnr.
    gv_scr_token = <lfs_alv>-zztoken.

    CASE <lfs_alv>-butikk(1).
      WHEN '1'. gv_scr_webshop = '1901'.
      WHEN '3'. gv_scr_webshop = '3821'.
      WHEN '4'. gv_scr_webshop = '4921'.
      WHEN '7'. gv_scr_webshop = '7921'.
    ENDCASE.

    gv_scr_guid = me->convert_guid_to_hyphen( iv_raw = <lfs_alv>-zzbpref ).

    " Perform old record check in the background for informational purposes only
    SELECT SINGLE refnr FROM zupdt_bp_token INTO @DATA(lv_dummy) WHERE refnr = @gv_scr_refnr.
    IF sy-subrc = 0.
      gv_refnr_exist = abap_true.
      gv_scr_msg     = 'Warning: Previous token records exist for this document. You can check details.'.
      gv_scr_icon1 = gv_scr_icon2 = gv_scr_icon3 = gv_scr_icon4 = icon_message_warning.
    ELSE.
      gv_scr_msg     = 'Ready to register new token update.'.
      gv_scr_icon1 = gv_scr_icon2 = gv_scr_icon3 = gv_scr_icon4 = icon_green_light.
    ENDIF.

    " Call the screen!
    CALL SCREEN 0400 STARTING AT 10 5 ENDING AT 115 15.

    IF sy-ucomm = 'SC_SE16N'.
      CLEAR sy-ucomm.
      me->tb_details( iv_table = 'ZUPDT_BP_TOKEN' ).
    ENDIF.
  ENDMETHOD.

  METHOD save_token.
    " Clean hidden spaces coming from the screen
    CONDENSE gv_scr_guid NO-GAPS.
    CONDENSE gv_scr_token. " Only use CONDENSE to avoid breaking the token format

    " Mandatory Field Checks
    IF gv_scr_token IS INITIAL.
      MESSAGE 'Token / Card Number is mandatory!' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    IF gv_scr_guid IS INITIAL.
      MESSAGE 'Partner GUID is mandatory!' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    " -----------------------------------------------------------------------
    "  GUID VALIDATION (Only 36 Characters and Hyphenated Format)
    " -----------------------------------------------------------------------
    DATA(lv_clean_guid) = gv_scr_guid.
    DATA(lv_guid_len)   = strlen( lv_clean_guid ).

    " Test 1: We only accept exactly 36 characters!
    IF lv_guid_len <> 36.
      MESSAGE 'Invalid length! You must enter the full 36-character hyphenated GUID.' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    " Test 2: Valid Character Check (Only Hexadecimal and Hyphens)
    IF lv_clean_guid CN '0123456789ABCDEFabcdef-'.
      MESSAGE 'Invalid characters! A GUID can only contain numbers (0-9), letters (A-F), and hyphens.' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    " Test 3: Hyphen positions must be exactly in 8-4-4-4-12 format!
    IF lv_clean_guid+8(1)  <> '-' OR
       lv_clean_guid+13(1) <> '-' OR
       lv_clean_guid+18(1) <> '-' OR
       lv_clean_guid+23(1) <> '-'.
      MESSAGE 'Invalid format! Hyphens must be placed exactly as: XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.
    " -----------------------------------------------------------------------

    "  Convert to RAW format using central method (ZUPDT format)
    DATA(lv_bpguid_raw) = me->convert_guid_to_raw( iv_guid = lv_clean_guid ).

    " Stop processing if the conversion fails for any reason!
    IF lv_bpguid_raw IS INITIAL.
      MESSAGE 'Critical Error: The provided GUID is corrupted and cannot be processed.' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    " EXACT RECORD CHECK
    SELECT SINGLE partner_guid INTO @DATA(lv_check_full)
      FROM zupdt_bp_token
     WHERE partner_guid = @lv_bpguid_raw
       AND token        = @gv_scr_token
       AND refnr        = @gv_scr_refnr.

    IF sy-subrc = 0.
      DATA: lv_ans_exact TYPE c.
      CALL FUNCTION 'POPUP_TO_CONFIRM'
        EXPORTING
          titlebar              = 'Warning: Exact Match!'
          text_question         = 'This EXACT SAME record (Same GUID & Token) already exists! Do you still want to insert a duplicate?'
          text_button_1         = 'Yes'
          text_button_2         = 'No'
          display_cancel_button = abap_true
        IMPORTING
          answer                = lv_ans_exact.

      IF lv_ans_exact <> '1'.
        MESSAGE 'Action cancelled.' TYPE 'S'.
        RETURN.
      ENDIF.

    ELSEIF gv_refnr_exist = abap_true.
      " DIFFERENT RECORD BUT SAME DOCUMENT CHECK (If not exact match but another record exists for the doc)
      DATA: lv_ans_diff TYPE c.
      CALL FUNCTION 'POPUP_TO_CONFIRM'
        EXPORTING
          titlebar              = 'Warning: Record Exists!'
          text_question         = |A different record already exists for Document { gv_scr_refnr }. Are you sure you want to add a NEW one?|
          text_button_1         = 'Yes'
          text_button_2         = 'No'
          display_cancel_button = abap_true
        IMPORTING
          answer                = lv_ans_diff.

      IF lv_ans_diff <> '1'.
        MESSAGE 'Action cancelled.' TYPE 'S'.
        RETURN.
      ENDIF.
    ENDIF.

    DATA: ls_zupdt TYPE zupdt_bp_token.
    ls_zupdt-partner_guid = lv_bpguid_raw.
    ls_zupdt-token        = gv_scr_token.
    ls_zupdt-refnr        = gv_scr_refnr.
    ls_zupdt-butikk       = gv_scr_webshop.
    ls_zupdt-created_date = sy-datum.
    ls_zupdt-created_time = sy-uzeit.
    ls_zupdt-status       = zcl_updt_bp_token=>gc_update_status_bp_missing.

    INSERT zupdt_bp_token FROM ls_zupdt.
    IF sy-subrc = 0.
      COMMIT WORK AND WAIT.

      READ TABLE me->get_selected_rows( ) INTO DATA(ls_row) INDEX 1.
      READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX ls_row-index.

      DATA(ls_new_alv) = <lfs_alv>.
      ls_new_alv-zzbpref = lv_clean_guid.
      ls_new_alv-zztoken = gv_scr_token.

      UPDATE zinsusale
           SET zzbpref = @lv_clean_guid,
               zztoken = @gv_scr_token
         WHERE refnr   = @<lfs_alv>-refnr
         AND polisenr =  @<lfs_alv>-polisenr.

      IF sy-subrc = 0.
        " Pass the comparison, comment text, and DB Update to central method
        me->add_auto_comment(
          iv_index    = ls_row-index
          iv_action   = 'Token Update Req.'
          is_new_data = ls_new_alv ).

        <lfs_alv>-zzbpref = lv_clean_guid.
        <lfs_alv>-zztoken = gv_scr_token.
        COMMIT WORK AND WAIT.
        MESSAGE 'New record successfully inserted!' TYPE 'S'.
        LEAVE TO SCREEN 0.
      ENDIF.
    ELSE.
      MESSAGE 'Database error during insertion!' TYPE 'S' DISPLAY LIKE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD convert_guid_to_raw.
    DATA(lv_clean) = iv_guid.
    CONDENSE lv_clean NO-GAPS.
    CHECK lv_clean IS NOT INITIAL.

    IF lv_clean CA '-'.
      TRY.
          rv_raw = cl_soap_wsrmb_helper=>convert_uuid_hyphened_to_raw( lv_clean ).
        CATCH cx_root.
          CLEAR rv_raw. " If it fails, it becomes 00000000000000000000000000000000
      ENDTRY.
    ELSE.
      " EVEN IF WITHOUT HYPHENS, FORCE TEST IF IT IS A VALID HEX!
      TRY.
          rv_raw = CONV bu_partner_guid( lv_clean ).
        CATCH cx_root.
          CLEAR rv_raw. " If it fails, it becomes 00000000000000000000000000000000
      ENDTRY.
    ENDIF.
  ENDMETHOD.

  METHOD convert_guid_to_hyphen.
    DATA(lv_clean) = CONV string( iv_raw ).
    CONDENSE lv_clean NO-GAPS.
    CHECK lv_clean IS NOT INITIAL.

    IF lv_clean NA '-'. " If it comes from ALV without hyphens (RAW), convert to hyphenated
      TRY.
          DATA(lv_raw_bytes) = CONV bu_partner_guid( lv_clean ).
          rv_guid = cl_soap_wsrmb_helper=>convert_uuid_raw_to_hyphened( lv_raw_bytes ).
        CATCH cx_root.
          rv_guid = lv_clean. " If it cannot be converted, leave as is; the 32/36 check in Save will catch it
      ENDTRY.
    ELSE.
      rv_guid = lv_clean. " Already hyphenated
    ENDIF.

    TRANSLATE rv_guid TO UPPER CASE.
  ENDMETHOD.

  METHOD add_auto_comment.
    READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX iv_index.
    CHECK sy-subrc = 0.

    DATA: lv_added       TYPE string,
          lv_changed     TYPE string,
          lv_action_text TYPE string.

    lv_action_text = iv_action. " E.g.: 'Token Update Req.' or 'Mail Sent.'

    " 1. IF NEW DATA IS PROVIDED, COMPARISON
    IF is_new_data IS SUPPLIED.

      " -- GUID Comparison --
      IF is_new_data-zzbpref IS NOT INITIAL AND <lfs_alv>-zzbpref IS INITIAL.
        lv_added = lv_added && |GUID, |.
      ELSEIF is_new_data-zzbpref <> <lfs_alv>-zzbpref.
        lv_changed = lv_changed && |GUID, |.
      ENDIF.

      " -- Token Comparison --
      IF is_new_data-zztoken IS NOT INITIAL AND <lfs_alv>-zztoken IS INITIAL.
        lv_added = lv_added && |Token, |.
      ELSEIF is_new_data-zztoken <> <lfs_alv>-zztoken.
        lv_changed = lv_changed && |Token, |.
      ENDIF.

      " -- IMEI Comparison --
      IF is_new_data-zz_imei IS NOT INITIAL AND <lfs_alv>-zz_imei IS INITIAL.
        lv_added = lv_added && |IMEI, |.
      ELSEIF is_new_data-zz_imei <> <lfs_alv>-zz_imei.
        lv_changed = lv_changed && |IMEI, |.
      ENDIF.

      " Formatting the Output (Clean the trailing ', ' comma and spaces)
      IF lv_added IS NOT INITIAL.
        DATA(lv_len_a) = strlen( lv_added ) - 2.
        lv_added = lv_added(lv_len_a).
        lv_action_text = lv_action_text && | -> Added: ({ lv_added })|.
      ENDIF.

      IF lv_changed IS NOT INITIAL.
        DATA(lv_len_c) = strlen( lv_changed ) - 2.
        lv_changed = lv_changed(lv_len_c).
        lv_action_text = lv_action_text && | -> Changed: ({ lv_changed })|.
      ENDIF.

    ENDIF.

    " 2. CREATE COMMENT AND UPDATE ALV
    DATA(lv_prefix) = |{ sy-uname } { sy-datum DATE = USER }: |.

    IF <lfs_alv>-zcomment IS INITIAL.
      <lfs_alv>-zcomment = |{ lv_prefix }{ lv_action_text }|.
    ELSE.
      <lfs_alv>-zcomment = |{ lv_prefix }{ lv_action_text } // { <lfs_alv>-zcomment }|.
    ENDIF.

    " 3. DATABASE UPDATE (COMMENT FIELD ONLY!)
    UPDATE zinsusale
       SET zcomment = @<lfs_alv>-zcomment
     WHERE polisenr = @<lfs_alv>-polisenr.

    IF sy-subrc = 0.
      COMMIT WORK.
      mo_alv_grid->refresh_table_display( is_stable = gs_stable ).
    ENDIF.
  ENDMETHOD.

  METHOD get_selected_rows.

    mo_alv_grid->get_selected_rows( IMPORTING et_index_rows = rt_rows ).

    IF rt_rows IS INITIAL.
      MESSAGE 'Please, select a line!' TYPE 'S' DISPLAY LIKE 'W'.
