  METHOD tb_details.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    DATA: lt_selfields TYPE TABLE OF se16n_seltab,
          ls_selfield  TYPE se16n_seltab.

    LOOP AT lt_rows ASSIGNING FIELD-SYMBOL(<lfs_rows>). "Loop at selected rows
      READ TABLE mt_alv INDEX <lfs_rows>-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
      CHECK sy-subrc EQ 0."Continue to next row

      CLEAR ls_selfield.
      ls_selfield-sign = 'I'.
      ls_selfield-option = 'EQ'.

      IF iv_table = 'ZINSUSALE'.
        ls_selfield-field = 'POLISENR'.
        ls_selfield-low   = <lfs_alv>-polisenr.
      ELSEIF iv_table = 'ZUPDT_BP_TOKEN'.
        ls_selfield-field = 'REFNR'.
        ls_selfield-low   = <lfs_alv>-refnr.
      ENDIF.

      APPEND ls_selfield TO lt_selfields.
    ENDLOOP.

    CALL FUNCTION 'SE16N_INTERFACE'
      EXPORTING
        i_tab        = iv_table         " Table name in SE16N
        i_edit       = ' '              " Single-Character Indicator
        i_sapedit    = ' '              " Single-Character Indicator
*       i_no_txt     = ' '              " Do not select any texts
        i_max_lines  = 500              " Maximum Number of Hits
      TABLES
        it_selfields = lt_selfields     " Table Display: Selection Criteria
      EXCEPTIONS
        no_values    = 1                " No Values Found
        OTHERS       = 2.
    IF sy-subrc NE 0.
      MESSAGE | Could not bring details in { iv_table } | TYPE 'S' DISPLAY LIKE 'E'.
    ENDIF.
  ENDMETHOD.

  METHOD tb_update_token.
    DATA(lt_rows) = me->get_selected_rows( ).

    IF lines( lt_rows ) NE 1.
      MESSAGE 'Please select exactly ONE row for Token Update!' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    READ TABLE lt_rows INTO DATA(ls_row) INDEX 1.
    READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX ls_row-index.
    CHECK sy-subrc = 0.

    CLEAR: zupdt_bp_token-partner_guid, gv_scr_guid, gv_scr_token, gv_scr_refnr, gv_scr_webshop, gv_scr_bp, gv_scr_msg, gv_scr_mode, gv_refnr_exist.

    gv_scr_refnr = <lfs_alv>-refnr.
    gv_scr_token = <lfs_alv>-zztoken.

    CASE <lfs_alv>-butikk(1).
      WHEN '1'. gv_scr_webshop = '1901'.
      WHEN '3'. gv_scr_webshop = '3821'.
      WHEN '4'. gv_scr_webshop = '4921'.
      WHEN '7'. gv_scr_webshop = '7921'.
    ENDCASE.

    DATA: lv_alv_guid_raw TYPE bu_partner_guid.
    lv_alv_guid_raw = <lfs_alv>-zzbpref.

    SELECT SINGLE partner_guid INTO @DATA(lv_check_full) "Full key check
      FROM zupdt_bp_token
     WHERE partner_guid = @lv_alv_guid_raw
       AND token        = @gv_scr_token
       AND refnr        = @gv_scr_refnr.

    IF sy-subrc = 0. " Exact existing record -> Lock
      gv_scr_mode    = 'V'.
      gv_refnr_exist = abap_true.
      gv_scr_msg     = 'This exact record already exists. (Read-Only)'.

      IF <lfs_alv>-zzbpref IS NOT INITIAL.
        gv_scr_guid = cl_soap_wsrmb_helper=>convert_uuid_raw_to_hyphened( CONV #( <lfs_alv>-zzbpref ) ).
        zupdt_bp_token-partner_guid = <lfs_alv>-zzbpref.
      ENDIF.

    ELSE.

      SELECT * FROM zupdt_bp_token
            WHERE refnr = @gv_scr_refnr
            ORDER BY created_date DESCENDING, created_time DESCENDING
            INTO @DATA(ls_existing)
            UP TO 1 ROWS.
      ENDSELECT.

      IF sy-subrc = 0.  " Existing rec. -> Warning pop-up
        gv_refnr_exist = abap_true.

        DATA: lv_answer TYPE c.
        CALL FUNCTION 'POPUP_TO_CONFIRM'
          EXPORTING
            titlebar              = 'Warning: Record Exists!'
            text_question         = 'A different token update already exists for this document. Want to add a NEW one?'
            text_button_1         = 'Yes, Add New'
            text_button_2         = 'No, View Existing'
            display_cancel_button = abap_true
          IMPORTING
            answer                = lv_answer.

        IF lv_answer = 'A'. " Cancel
          RETURN.
        ENDIF.

        IF lv_answer = '1'. " Yes, Add New ->  editable
          gv_scr_mode = 'E'.
          gv_scr_msg  = 'Adding a new record for the same Document.'.
          IF <lfs_alv>-zzbpref IS NOT INITIAL.
            gv_scr_guid = cl_soap_wsrmb_helper=>convert_uuid_raw_to_hyphened( CONV #( <lfs_alv>-zzbpref ) ).
            zupdt_bp_token-partner_guid = ls_existing-partner_guid.
          ENDIF.
        ELSE.               " No, View Existing ->  Read-Only
          gv_scr_mode = 'V'.
          gv_scr_msg  = 'Showing existing record from Database. (Read-Only)'.
          IF ls_existing-partner_guid IS NOT INITIAL.
            gv_scr_guid = cl_soap_wsrmb_helper=>convert_uuid_raw_to_hyphened( ls_existing-partner_guid ).
            zupdt_bp_token-partner_guid = ls_existing-partner_guid.
          ENDIF.
          gv_scr_token = ls_existing-token.
          gv_scr_bp    = ls_existing-partner.
        ENDIF.

      ELSE.
        " No Rec. -> New Rec.
        gv_scr_mode = 'E'.
        gv_scr_msg  = 'Ready to register new token update.'.
        IF <lfs_alv>-zzbpref IS NOT INITIAL.
          gv_scr_guid = cl_soap_wsrmb_helper=>convert_uuid_raw_to_hyphened( CONV #( <lfs_alv>-zzbpref ) ).
          zupdt_bp_token-partner_guid = ls_existing-partner_guid.
        ENDIF.
      ENDIF.
    ENDIF.

    CALL SCREEN 0400 STARTING AT 10 5
                     ENDING   AT 105 15.

    IF sy-ucomm = 'SC_SE16N'.
      CLEAR sy-ucomm.
      me->tb_details( iv_table = 'ZUPDT_BP_TOKEN' ).
      RETURN.
    ENDIF.

    " Auto-Comment
    IF gv_save_success = abap_true.
      CLEAR gv_save_success.

      DATA: lv_new_comment TYPE string,
            lv_db_update   TYPE abap_bool.

      lv_new_comment = 'Token Update Req.'.

      IF gv_scr_guid IS NOT INITIAL.
        DATA(lv_raw_guid) = cl_soap_wsrmb_helper=>convert_uuid_hyphened_to_raw( gv_scr_guid ).
        IF <lfs_alv>-zzbpref <> lv_raw_guid.
          lv_new_comment    = lv_new_comment && ' (GUID Added / Changed)'.
          <lfs_alv>-zzbpref = lv_raw_guid.
          lv_db_update      = abap_true.
        ENDIF.
      ENDIF.

      IF gv_scr_token IS NOT INITIAL AND <lfs_alv>-zztoken <> gv_scr_token.
        lv_new_comment    = lv_new_comment && ' (Token eklendi/gnclendi)'.
        <lfs_alv>-zztoken = gv_scr_token.
        lv_db_update      = abap_true.
      ENDIF.

      me->add_auto_comment( iv_index = ls_row-index iv_text = lv_new_comment ).

      IF lv_db_update = abap_true.
        UPDATE zinsusale
           SET zzbpref = @<lfs_alv>-zzbpref,
               zztoken = @<lfs_alv>-zztoken
         WHERE polisenr = @<lfs_alv>-polisenr.

        IF sy-subrc = 0.
          COMMIT WORK AND WAIT.
        ENDIF.
      ENDIF.

      mo_alv_grid->refresh_table_display( is_stable = gs_stable ).

    ENDIF.
  ENDMETHOD.

  METHOD add_auto_comment.
    READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_alv>) INDEX iv_index.
    CHECK sy-subrc = 0.

    DATA(lv_prefix) = |{ sy-uname } { sy-datum DATE = USER }: |.
    IF <lfs_alv>-zcomment IS INITIAL.
      <lfs_alv>-zcomment = |{ lv_prefix }{ iv_text }|.
    ELSE.
      <lfs_alv>-zcomment = |{ lv_prefix }{ iv_text } // { <lfs_alv>-zcomment }|.
    ENDIF.

    UPDATE zinsusale
       SET zcomment = @<lfs_alv>-zcomment
     WHERE polisenr = @<lfs_alv>-polisenr.

    IF sy-subrc = 0.
      COMMIT WORK.
      mo_alv_grid->refresh_table_display( is_stable = gs_stable ).
    ENDIF.
  ENDMETHOD.

