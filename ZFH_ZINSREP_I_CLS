      ls_queue-mail_subj = |Subscription Insurance Sales - #{ ls_queue-mail_id }|.

      APPEND 'Hi VIP Team,' TO ls_queue-mail_body.
      APPEND ' ' TO ls_queue-mail_body.
      APPEND 'We have received the following subscription insurance sales in SAP, but due to Voyado issues we can not create the Subscription.' TO ls_queue-mail_body.
      APPEND ' ' TO ls_queue-mail_body.

      DATA: lt_valid_rows TYPE lvc_t_row.
      CLEAR lt_valid_rows.

      LOOP AT ls_grp-rows INTO DATA(ls_grp_row).
        READ TABLE me->mt_alv ASSIGNING FIELD-SYMBOL(<lfs_a>) INDEX ls_grp_row-index.

*------------------------Process for Missing GUID:--------------------------------------------*
        IF <lfs_a>-zzbpref IS INITIAL OR <lfs_a>-zzbpref NS '-'.
          APPEND ls_grp_row TO lt_valid_rows.
*          me->add_message( iv_type = 'S' iv_text = |Policy: { <lfs_a>-polisenr }, Mail Id: #{ ls_queue-mail_id }, Sent!| ).

          APPEND |We need Voyado ID for this sale { <lfs_a>-refnr } | TO ls_queue-mail_body.
