  METHOD tb_check_voyado_missing.
    DATA: lo_request TYPE REF TO zco_business_partner_by_elemen,
          ls_output  TYPE zbusiness_partner_by_elements2.

    " Determine Webshop ID based on Store code (Dynamic)
    DATA(lv_webshop) = SWITCH string( iv_store(1)
                         WHEN '1' THEN '1901'
                         WHEN '3' THEN '3821'
                         WHEN '4' THEN '4921'
                         WHEN '7' THEN '7921'
                         ELSE iv_store ). " If no match, send the store code itself

    " Fill API Inputs
    ls_output-business_partner_by_elements_q-business_partner_update_reques-business_partner_uuid-content = me->convert_guid_to_raw( iv_guid = iv_guid ).
    ls_output-business_partner_by_elements_q-business_partner_update_reques-main_webshop = lv_webshop.

    TRY.
        CREATE OBJECT lo_request.
        lo_request->business_partner_by_elements_q(
          EXPORTING output = ls_output
          IMPORTING input  = DATA(ls_input) ).
      CATCH cx_ai_system_fault.
        rv_missing = 'API_ERROR'.
        RETURN.
    ENDTRY.

    DATA: lt_missing TYPE TABLE OF string.
    LOOP AT ls_input-business_partner_by_elements_q-info-value ASSIGNING FIELD-SYMBOL(<namedvalue>).
      " If error_code is filled, it indicates the information is missing/incorrect
      IF <namedvalue>-error_code IS NOT INITIAL.
        APPEND <namedvalue>-name TO lt_missing.
      ENDIF.
    ENDLOOP.

    IF lt_missing IS NOT INITIAL.
      CONCATENATE LINES OF lt_missing INTO rv_missing SEPARATED BY ', '.
    ELSE.
      rv_missing = 'ALL_OK'.
    ENDIF.
  ENDMETHOD.

  METHOD tb_check_voyado_btn.
    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    IF lines( lt_rows ) > 1.
      MESSAGE 'Please select only ONE row to check Voyado!' TYPE 'S' DISPLAY LIKE 'W'.
      RETURN.
    ENDIF.

    READ TABLE lt_rows INTO DATA(ls_row) INDEX 1.
    READ TABLE mt_alv INDEX ls_row-index ASSIGNING FIELD-SYMBOL(<lfs_alv>).
    CHECK sy-subrc = 0.

    IF <lfs_alv>-zzsubscr IS INITIAL.
      MESSAGE | Policy: { <lfs_alv>-polisenr } is not a subscription! | TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    IF <lfs_alv>-zzbpref IS INITIAL OR <lfs_alv>-zzbpref NS '-'.
      MESSAGE 'A valid GUID is required to check Voyado!' TYPE 'S' DISPLAY LIKE 'E'.
      RETURN.
    ENDIF.

    " Call the API and get the result
    DATA(lv_missing) = me->tb_check_voyado_missing( iv_guid = CONV #( <lfs_alv>-zzbpref ) iv_store = <lfs_alv>-butikk ).

    " Show Result to User
    IF lv_missing = 'API_ERROR'.
      MESSAGE 'Connection to Voyado failed! Please try again.' TYPE 'S' DISPLAY LIKE 'E'.
    ELSEIF lv_missing = 'ALL_OK'.
      MESSAGE 'All mandatory fields are filled in Voyado. No missing data!' TYPE 'S'.
    ELSE.
      " Show missing fields via Pop-up (for easier readability)
      MESSAGE |Missing/Erroneous fields: { lv_missing }| TYPE 'I'.
    ENDIF.

  ENDMETHOD.

