  METHOD tb_prepare_mail.
* Color              <span style="color: red;"> TEXT </span>.
* Background Color   <span style="background-color: yellow;" TEXT </span>'

    DATA(lt_rows) = me->get_selected_rows( ).
    CHECK lt_rows IS NOT INITIAL.

    CLEAR: gt_mail_queue.

    "Temporarily Group by Countries
    TYPES: BEGIN OF ty_temp_grp,
             country TYPE string,
             store   TYPE zbutikk,
             rows    TYPE lvc_t_row,
           END OF ty_temp_grp.
