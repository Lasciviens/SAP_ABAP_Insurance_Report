  METHOD add_message.
    DATA: ls_msg  TYPE bapiret2,
          lv_text TYPE char200.

    lv_text = iv_text.

    ls_msg-type       = iv_type.
    ls_msg-id         = '00'.
    ls_msg-number     = '398'.
    ls_msg-message    = iv_text.

    ls_msg-message_v1 = lv_text(50).
    ls_msg-message_v2 = lv_text+50(50).
    ls_msg-message_v3 = lv_text+100(50).
    ls_msg-message_v4 = lv_text+150(50).

    APPEND ls_msg TO me->mt_messages.
  ENDMETHOD.
